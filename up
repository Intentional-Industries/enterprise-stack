#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TERRAFORM_DIR="$ROOT_DIR/terraform"
APP_DIR="$ROOT_DIR/app"

# ── Variables ────────────────────────────────────────────────────────────────
PROJECT="${PROJECT:-intentional}"
ENVIRONMENT="${ENVIRONMENT:-dev}"
AWS_REGION="${AWS_REGION:-us-east-1}"
export AWS_PROFILE="${AWS_PROFILE:-intentional}"

# ── 1. Prerequisite checks ────────────────────────────────────────────────────
log() { echo "[$(date -u +%H:%M:%S)] $*"; }

log "Checking prerequisites..."
for cmd in aws terraform docker jq; do
  command -v "$cmd" >/dev/null || { echo "ERROR: $cmd not found"; exit 1; }
done

AWS_ACCOUNT_ID=$(aws sts get-caller-identity --profile "$AWS_PROFILE" --query Account --output text)
log "AWS account: $AWS_ACCOUNT_ID (profile: $AWS_PROFILE)"

# ── 2. Bootstrap remote state backend ────────────────────────────────────────
STATE_BUCKET="${PROJECT}-terraform-state-${AWS_ACCOUNT_ID}"

log "Bootstrapping state backend..."

# Create S3 bucket if it doesn't exist
if ! aws s3api head-bucket --bucket "$STATE_BUCKET" --profile "$AWS_PROFILE" 2>/dev/null; then
  log "Creating state bucket $STATE_BUCKET..."
  if [ "$AWS_REGION" = "us-east-1" ]; then
    aws s3api create-bucket --bucket "$STATE_BUCKET" --profile "$AWS_PROFILE" --region "$AWS_REGION"
  else
    aws s3api create-bucket --bucket "$STATE_BUCKET" --profile "$AWS_PROFILE" --region "$AWS_REGION" \
      --create-bucket-configuration LocationConstraint="$AWS_REGION"
  fi
  aws s3api put-bucket-versioning --bucket "$STATE_BUCKET" --profile "$AWS_PROFILE" \
    --versioning-configuration Status=Enabled
  aws s3api put-bucket-encryption --bucket "$STATE_BUCKET" --profile "$AWS_PROFILE" \
    --server-side-encryption-configuration '{"Rules":[{"ApplyServerSideEncryptionByDefault":{"SSEAlgorithm":"AES256"}}]}'
  aws s3api put-public-access-block --bucket "$STATE_BUCKET" --profile "$AWS_PROFILE" \
    --public-access-block-configuration "BlockPublicAcls=true,IgnorePublicAcls=true,BlockPublicPolicy=true,RestrictPublicBuckets=true"
fi

# ── 3. Terraform init ─────────────────────────────────────────────────────────
log "Initializing Terraform..."
cd "$TERRAFORM_DIR"

# Write backend config dynamically (not committed to repo)
cat > backend.tf <<BACKENDEOF
terraform {
  backend "s3" {
    bucket         = "${STATE_BUCKET}"
    key            = "${PROJECT}/${ENVIRONMENT}/terraform.tfstate"
    region         = "${AWS_REGION}"
    use_lockfile   = true
    encrypt        = true
  }
}
BACKENDEOF

terraform init -reconfigure

# ── 4. First-pass apply to bootstrap ECR ─────────────────────────────────────
# ECR must exist before we can push the image; use a placeholder image for this pass.
log "Applying Terraform (phase 1 — ECR bootstrap)..."
terraform apply -auto-approve \
  -var="project=${PROJECT}" \
  -var="environment=${ENVIRONMENT}" \
  -var="aws_region=${AWS_REGION}" \
  -var="app_image=public.ecr.aws/amazonlinux/amazonlinux:latest" \
  -target="module.observability" \
  -var-file="environments/dev/terraform.tfvars" 2>&1 | tail -20

ECR_REPO_URL=$(terraform output -raw ecr_repository_url 2>/dev/null || true)
log "ECR repository: $ECR_REPO_URL"

# ── 5. Build & push Docker image ──────────────────────────────────────────────
log "Building Docker image..."
cd "$APP_DIR"

GIT_SHA=$(git -C "$ROOT_DIR" rev-parse --short HEAD 2>/dev/null || date +%s)
IMAGE_TAG="${PROJECT}-${ENVIRONMENT}-${GIT_SHA}"
FULL_IMAGE="${ECR_REPO_URL}:${IMAGE_TAG}"

docker build -t "$FULL_IMAGE" .

log "Authenticating with ECR..."
aws ecr get-login-password --profile "$AWS_PROFILE" --region "$AWS_REGION" | \
  docker login --username AWS --password-stdin "${ECR_REPO_URL%%/*}"

log "Pushing image $FULL_IMAGE..."
docker push "$FULL_IMAGE"

# ── 6. Full Terraform apply ───────────────────────────────────────────────────
log "Applying Terraform (full stack)..."
cd "$TERRAFORM_DIR"

terraform apply -auto-approve \
  -var="project=${PROJECT}" \
  -var="environment=${ENVIRONMENT}" \
  -var="aws_region=${AWS_REGION}" \
  -var="app_image=${FULL_IMAGE}" \
  -var-file="environments/dev/terraform.tfvars"

# ── 7. Run DB migrations ──────────────────────────────────────────────────────
log "Running database migrations..."
CLUSTER=$(terraform output -raw ecs_cluster_name)
MIGRATION_TASK_DEF=$(terraform output -raw migration_task_definition_arn)
PRIVATE_SUBNETS=$(terraform output -json private_subnet_ids | jq -r 'join(",")')
ECS_SG=$(terraform output -raw ecs_sg_id 2>/dev/null || true)

TASK_ARN=$(aws ecs run-task \
  --cluster "$CLUSTER" \
  --task-definition "$MIGRATION_TASK_DEF" \
  --launch-type FARGATE \
  --network-configuration "awsvpcConfiguration={subnets=[${PRIVATE_SUBNETS}],securityGroups=[${ECS_SG}],assignPublicIp=DISABLED}" \
  --profile "$AWS_PROFILE" \
  --region "$AWS_REGION" \
  --query 'tasks[0].taskArn' \
  --output text)

log "Migration task: $TASK_ARN — waiting for completion..."
aws ecs wait tasks-stopped \
  --cluster "$CLUSTER" \
  --tasks "$TASK_ARN" \
  --profile "$AWS_PROFILE" \
  --region "$AWS_REGION"

EXIT_CODE=$(aws ecs describe-tasks \
  --cluster "$CLUSTER" \
  --tasks "$TASK_ARN" \
  --profile "$AWS_PROFILE" \
  --region "$AWS_REGION" \
  --query 'tasks[0].containers[0].exitCode' \
  --output text)

[ "$EXIT_CODE" = "0" ] || { log "ERROR: Migration task failed (exit $EXIT_CODE)"; exit 1; }
log "Migrations complete."

# ── 8. Wait for service to stabilise ─────────────────────────────────────────
log "Waiting for ECS service to stabilise..."
SERVICE=$(terraform output -raw ecs_service_name)
aws ecs wait services-stable \
  --cluster "$CLUSTER" \
  --services "$SERVICE" \
  --profile "$AWS_PROFILE" \
  --region "$AWS_REGION"

# ── 9. Print app URL ──────────────────────────────────────────────────────────
CF_DOMAIN=$(terraform output -raw cloudfront_domain)
APP_URL="https://${CF_DOMAIN}"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "App is live at: $APP_URL"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

# ── 10. Run acceptance tests ──────────────────────────────────────────────────
log "Running V1 acceptance tests..."
cd "$ROOT_DIR"

APP_URL="$APP_URL" \
  AWS_PROFILE="$AWS_PROFILE" \
  AWS_REGION="$AWS_REGION" \
  COGNITO_USER_POOL_ID="$(cd "$TERRAFORM_DIR" && terraform output -raw cognito_user_pool_id)" \
  DB_SECRET_ARN="$(cd "$TERRAFORM_DIR" && terraform output -raw db_secret_arn)" \
  ECS_CLUSTER="$CLUSTER" \
  ./test

log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
log "V1 acceptance gate: PASSED"
log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
