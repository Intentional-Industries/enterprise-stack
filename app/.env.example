# AWS
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXX
COGNITO_CLIENT_ID=XXXXX

# Database (injected from Secrets Manager in production via ECS secrets)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intentional
DB_USERNAME=intentional_admin
DB_PASSWORD=changeme

# Session signing key (injected from Secrets Manager in production)
SESSION_SECRET=dev-secret-change-in-production-min-32-chars

# App URL (used for redirect in sign-out)
NEXTAUTH_URL=http://localhost:3000

# OpenTelemetry — omit to log traces to stdout only
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
