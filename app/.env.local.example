# Local development config — used by ./dev
# Copy to .env.local (gitignored) or let ./dev do it for you.

# Database — matches docker-compose.yml defaults
# Port 5433 (not the Postgres default 5432) to avoid colliding with any
# Postgres already running on your machine (Postgres.app, homebrew, etc.).
DB_HOST=localhost
DB_PORT=5433
DB_NAME=intentional
DB_USERNAME=intentional_admin
DB_PASSWORD=changeme
# Local Postgres (docker-compose) doesn't speak TLS; production RDS does.
DB_SSL=false

# Session signing key (any string ≥32 chars works locally)
SESSION_SECRET=dev-secret-change-in-production-min-32-chars

# App URL (used for redirect in sign-out). next dev falls back to the next
# free port (3001, 3002, ...) if 3000 is taken — update this to match
# whatever port the "Local:" line in the ./dev output actually shows.
NEXTAUTH_URL=http://localhost:3001

# Cognito — emulated locally by cognito-local (docker-compose), no AWS needed.
# ./dev creates a user pool + client on first run and writes the two IDs
# below automatically (via `npm run cognito:setup`) — you don't set them by hand.
AWS_REGION=us-east-1
COGNITO_ENDPOINT=http://localhost:9229
COGNITO_PORT=9229
# COGNITO_USER_POOL_ID=
# COGNITO_CLIENT_ID=

# To instead test against a REAL AWS Cognito pool (e.g. one from `./up`):
# comment out COGNITO_ENDPOINT above, set COGNITO_USER_POOL_ID/COGNITO_CLIENT_ID
# to the real pool's values, and make sure your shell has AWS credentials that
# can call it.

# OpenTelemetry — omit to log traces to stdout only
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
